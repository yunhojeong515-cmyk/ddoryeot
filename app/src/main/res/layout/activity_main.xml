<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:orientation="vertical"
    android:fitsSystemWindows="true"
    android:paddingStart="32dp"
    android:paddingEnd="32dp">

    <!-- 우측 상단 설정 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="end"
        android:paddingTop="0dp">

        <ImageButton
            android:id="@+id/btnSettings"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginEnd="12dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_settings"
            android:scaleType="fitCenter"
            android:contentDescription="설정" />
    </LinearLayout>

    <!-- 상단 여백 -->
    <Space android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="2" />

    <!-- 로고 + 부제목 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/app_logo"
            android:textSize="72sp"
            android:textColor="#FF3B30"
            android:fontFamily="@font/moneygraphy"
            android:maxLines="1"
            android:gravity="center"
            android:autoSizeTextType="uniform"
            android:autoSizeMinTextSize="32sp"
            android:autoSizeMaxTextSize="72sp"
            android:autoSizeStepGranularity="2sp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/home_subtitle"
            android:textSize="20sp"
            android:textColor="#8E8E93"
            android:fontFamily="@font/moneygraphy"
            android:gravity="center"
            android:lineSpacingExtra="4dp"
            android:layout_marginTop="8dp" />
    </LinearLayout>

    <!-- 로고와 버튼 사이 여백 -->
    <Space android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="2" />

    <!-- 버튼 (가로 70% = 기존 대비 30% 축소) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Space
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="15" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="70"
            android:orientation="vertical">

            <Button
                android:id="@+id/btnStart"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:text="@string/btn_start"
                android:textSize="22sp"
                android:textColor="#FFFFFF"
                android:fontFamily="@font/moneygraphy"
                android:background="@drawable/btn_primary"
                android:stateListAnimator="@null" />

            <Button
                android:id="@+id/btnStop"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:text="@string/btn_stop"
                android:textSize="22sp"
                android:textColor="#FFFFFF"
                android:fontFamily="@font/moneygraphy"
                android:background="@drawable/btn_secondary"
                android:stateListAnimator="@null"
                android:layout_marginTop="14dp" />
        </LinearLayout>

        <Space
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="15" />
    </LinearLayout>

    <!-- 버튼과 하단 문구 사이 여백 -->
    <Space android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="3" />

    <!-- 하단 안내 문구 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingBottom="48dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/guide_line1"
            android:textSize="18sp"
            android:textColor="#8E8E93"
            android:fontFamily="@font/moneygraphy" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="6dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/guide_red_box"
                android:textSize="22sp"
                android:textColor="#FF3B30"
                android:fontFamily="@font/moneygraphy" />

            <View
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:background="@drawable/standby_square" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/guide_line3"
            android:textSize="18sp"
            android:textColor="#8E8E93"
            android:fontFamily="@font/moneygraphy" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/made_by"
            android:textSize="12sp"
            android:textColor="#C7C7CC"
            android:fontFamily="@font/moneygraphy"
            android:layout_marginTop="14dp" />
    </LinearLayout>

</LinearLayout>
